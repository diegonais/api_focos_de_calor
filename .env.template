# ==============================
# Aplicacion
# ==============================
PORT=3000
NODE_ENV=development
TZ=America/La_Paz

# ==============================
# NASA FIRMS
# ==============================
# API key oficial para NASA FIRMS
FIRMS_MAP_KEY=
FIRMS_BASE_URL=https://firms.modaps.eosdis.nasa.gov/api/area/csv
FIRMS_BBOX=-69.8,-22.9,-57.4,-9.6
FIRMS_ENABLED_SOURCES=VIIRS_SNPP_NRT,VIIRS_NOAA20_NRT,VIIRS_NOAA21_NRT,MODIS_NRT
FIRMS_INITIAL_SYNC_START_DATE=2026-01-01
FIRMS_LOOKBACK_DAYS=4
FIRMS_SYNC_EVERY_MINUTES=5
FIRMS_RUN_ON_BOOT=true
FIRMS_REQUEST_TIMEOUT_MS=15000

# ==============================
# Base de datos remota (Neon)
# Si DATABASE_URL tiene valor, la API usara esta conexion
# y omitira las variables DB_HOST, DB_PORT, DB_USERNAME,
# DB_PASSWORD y DB_NAME.
# ==============================
DATABASE_URL=

# ==============================
# Base de datos local/estandar
# Estas variables aplican cuando DATABASE_URL esta vacia.
# DB_PORT es el puerto publicado en tu maquina host.
# Si PostgreSQL corre con Docker Compose, la API local
# debe usar DB_HOST=localhost y este DB_PORT.
# ==============================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=user
DB_PASSWORD=password
DB_NAME=name
DB_SSL=false
DB_SYNCHRONIZE=false
DB_LOGGING=false